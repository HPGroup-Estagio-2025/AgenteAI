# Copia este ficheiro para .env.local e preenche os valores reais.
# Nunca coloques credenciais reais neste ficheiro de exemplo.

# Porta do servidor
PORT=3000

# Seguranca JWT
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=coloca-aqui-um-segredo-muito-longo-e-aleatorio

# Credenciais do admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=altera-esta-password

# Origem permitida (CORS)
ALLOWED_ORIGIN=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://teu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=coloca-aqui-a-anon-key
SUPABASE_NEWS_TABLE=news

# URL publica/base da app usada nos callbacks OAuth
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Facebook OAuth
FACEBOOK_APP_ID=coloca-aqui-o-app-id
FACEBOOK_APP_SECRET=coloca-aqui-o-app-secret

# Opcional: escolher a Pagina exata onde publicar.
# Se ficar vazio, usa a primeira Pagina devolvida pelo Facebook Login.
FACEBOOK_PAGE_ID=

# Se true, o dashboard tenta publicar diretamente na Pagina do Facebook.
# Se false, apenas valida a conta ligada e envia a acao para o N8N_PUBLISH_WEBHOOK.
FACEBOOK_DIRECT_PUBLISH=false

# Instagram OAuth
# A app usa o Facebook Login/Graph API para ligar Instagram Business.
# Por isso, o Instagram usa FACEBOOK_APP_ID e FACEBOOK_APP_SECRET.

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=coloca-aqui-o-client-id
LINKEDIN_CLIENT_SECRET=coloca-aqui-o-client-secret

# Ficheiro local onde ficam guardadas as contas OAuth ligadas.
# Contem tokens de acesso; deve ficar fora do Git.
SOCIAL_ACCOUNTS_FILE=.data/social-accounts.json

# Webhooks n8n
N8N_PUBLISH_WEBHOOK=
N8N_REJECT_WEBHOOK=
